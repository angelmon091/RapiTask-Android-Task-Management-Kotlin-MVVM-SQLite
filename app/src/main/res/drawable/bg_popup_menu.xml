<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Sombreado simulado -->
    <item android:left="1dp" android:top="1dp">
        <shape>
            <corners android:radius="16dp" />
            <solid android:color="#1A000000" />
        </shape>
    </item>
    <!-- Fondo principal usando el color específico para componentes -->
    <item android:bottom="1dp" android:right="1dp">
        <shape>
            <solid android:color="@color/component_surface" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="@color/outline" />
        </shape>
    </item>
</layer-list>