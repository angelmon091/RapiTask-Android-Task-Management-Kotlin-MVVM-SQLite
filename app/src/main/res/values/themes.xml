<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ProyectoFinal" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/on_secondary_container</item>

        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/on_secondary_container</item>

        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorOnTertiary">@color/on_tertiary</item>
        <item name="colorTertiaryContainer">@color/tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/on_tertiary_container</item>

        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>

        <!-- Barra de estado y navegación transparentes -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>

        <!-- Estilo de PopupMenu y Diálogos COMPARTIDO -->
        <item name="popupMenuStyle">@style/CustomPopupMenuStyle</item>
        <item name="alertDialogTheme">@style/CustomAlertDialogTheme</item>
        <item name="materialAlertDialogTheme">@style/CustomAlertDialogTheme</item>
    </style>

    <style name="Theme.ProyectoFinal" parent="Base.Theme.ProyectoFinal" />

    <!-- Estilo de Menú Neutro -->
    <style name="CustomPopupMenuStyle" parent="Widget.Material3.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_popup_menu</item>
    </style>

    <!-- Estilo para diálogos Neutro -->
    <style name="CustomAlertDialogTheme" parent="Theme.Material3.DayNight.Dialog.Alert">
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Dialog</item>
        <item name="colorSurface">@color/component_surface</item>
        <item name="colorOnSurface">@color/component_on_surface</item>
        <item name="backgroundTint">@color/component_surface</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

    <style name="ShapeAppearance.Dialog" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Tema para la Pantalla de Carga -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/logoapp</item>
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <item name="postSplashScreenTheme">@style/Theme.ProyectoFinal</item>
    </style>

    <!-- Estilos restaurados para evitar errores de compilación -->
    <style name="TextAppearance.App.NavSubheader" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ThemeOverlay.App.Toolbar" parent="ThemeOverlay.Material3.ActionBar">
        <item name="colorControlNormal">@color/on_surface</item>
    </style>

    <style name="CalendarDateTextAppearance" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="CalendarWeekDayTextAppearance" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="Widget.App.CalendarView" parent="android:Widget.CalendarView">
        <item name="android:focusedMonthDateColor">?attr/colorOnSurface</item>
        <item name="android:unfocusedMonthDateColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:weekSeparatorLineColor">@android:color/transparent</item>
    </style>
</resources>
